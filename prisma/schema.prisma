generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Coach {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  features    Json     @default("{\"enable_user_ratings\": true, \"rating_method\": \"in-app\", \"enable_post_session_email\": false, \"email_delay_hours\": 24}")
  llmConfig   Json     @default("{\"content_strategy\": \"curated_only\", \"web_search_enabled\": false, \"agent_mode\": \"coach\", \"personality\": {\"tone\": \"professional_coach\", \"transparency_level\": \"low\"}, \"model\": \"claude-sonnet-4-5-20250929\", \"temperature\": 0.7, \"max_tokens\": 500}") @map("llm_config")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  taxonomies        Taxonomy[]
  interviewSessions InterviewSession[]

  @@map("coaches")
}

model Taxonomy {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId      String   @map("coach_id") @db.Uuid
  taxonomyType String   @map("taxonomy_type")
  name         String
  slug         String
  parentId     String?  @map("parent_id") @db.Uuid
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  coach    Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  parent   Taxonomy? @relation("TaxonomyHierarchy", fields: [parentId], references: [id])
  children Taxonomy[] @relation("TaxonomyHierarchy")

  @@unique([coachId, taxonomyType, slug])
  @@index([coachId])
  @@index([taxonomyType])
  @@index([parentId])
  @@map("taxonomies")
}

enum agent_type {
  Guide
  Analyst
  Builder
  Orchestrator
}

model Agent {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @map("agent_id") @db.Uuid
  name                String
  prompt              String?
  documentTags        String[]    @default([]) @map("document_tags")
  status              String      @default("draft")
  agentType           agent_type? @map("agent_type")
  liveResearchEnabled Boolean     @default(false) @map("live_research_enabled")
  createdAt           DateTime    @default(now()) @map("created_at")

  @@index([status])
  @@map("agents")
}

model KnowledgeBaseDocument {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  category     String
  personaType  String?  @map("persona_type")
  content      String
  agents       String[]
  weight       Int      @default(5)
  status       String   @default("draft")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  chunks KnowledgeBaseChunk[]

  @@index([category])
  @@index([status])
  @@map("knowledge_base_documents")
}

model KnowledgeBaseChunk {
  id         String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String                       @map("document_id") @db.Uuid
  content    String?
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int?                         @map("chunk_index")
  agents     String[]
  category   String?
  createdAt  DateTime                     @default(now()) @map("created_at")

  document KnowledgeBaseDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("knowledge_base_chunks")
}

model InterviewSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coachId          String    @map("coach_id") @db.Uuid
  userEmail        String?   @map("user_email")
  userName         String?   @map("user_name")
  interviewConfig  Json      @map("interview_config")
  transcript       String?
  scorecardData    Json?     @map("scorecard_data")
  userRating       Int?      @map("user_rating")
  ratingSource     String?   @map("rating_source")
  userFeedback     String?   @map("user_feedback")
  ratingCapturedAt DateTime? @map("rating_captured_at")
  retrievedChunks  Json?     @map("retrieved_chunks")
  aiModelUsed      String?   @map("ai_model_used")
  promptVersion    String?   @map("prompt_version")
  createdAt        DateTime  @default(now()) @map("created_at")
  completedAt      DateTime? @map("completed_at")

  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([userRating])
  @@index([createdAt])
  @@map("interview_sessions")
}

model assessment_comments {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id String      @db.Uuid
  version_id    String?     @db.Uuid
  anchor_text   String
  body          String
  author_id     String      @db.Uuid
  tagged_users  String[]    @default([]) @db.Uuid
  resolved      Boolean     @default(false)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  assessments   assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
  @@map("assessment_comments")
}

model assessment_documents {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id    String            @db.Uuid
  filename         String
  file_size        Int
  storage_path     String
  extracted_text   String?
  uploaded_at      DateTime          @default(now()) @db.Timestamptz(6)
  assessments      assessments       @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  document_chunks  document_chunks[]

  @@index([assessment_id])
  @@map("assessment_documents")
}

model assessment_versions {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id   String      @db.Uuid
  version_number  String
  content_json    Json
  summary         String?
  created_by      String      @db.Uuid
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  assessments     assessments @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
  @@map("assessment_versions")
}

model assessments {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_by           String                 @db.Uuid
  client_name          String
  stakeholders         String[]               @default([])
  project_brief        String?
  draft_content        Json?
  status               String                 @default("new")
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @updatedAt @db.Timestamptz(6)
  deleted_at           DateTime?              @db.Timestamptz(6)
  assessment_comments  assessment_comments[]
  assessment_documents assessment_documents[]
  assessment_versions  assessment_versions[]

  @@index([created_by])
  @@index([status])
  @@map("assessments")
}

model document_chunks {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id         String                 @db.Uuid
  document_id           String                 @db.Uuid
  chunk_index           Int
  content               String
  embedding             Unsupported("vector(1536)")?
  assessment_documents  assessment_documents   @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([assessment_id])
  @@index([document_id])
  @@map("document_chunks")
}
